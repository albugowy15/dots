# GLOBAL
max-history=100
sort=-time

# BINDING OPTIONS
on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action
on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/message.oga

# STYLE OPTIONS
font= monospace 10
width=300
height=100
margin=10
padding=10
border-size=1
border-radius=5
icons=1
max-icon-size=34
icon-location=left
actions=1
history=1
text-alignment=center
default-timeout=5000
ignore-timeout=0
max-visible=5

background-color=#141415 
text-color=#cdcdcd
border-color=#606079
progress-color=over #606079

[urgency=low]
border-color=#606079
default-timeout=2000

[urgency=normal]
border-color=#606079
default-timeout=4000

[urgency=high]
border-color=#d8647e
text-color=#d8647e
default-timeout=6000
